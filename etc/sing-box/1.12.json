{
  "log": {"disabled": false, "level": "debug", "output": "/etc/sing-box/sing-box.log", "timestamp": true},
  "dns": {
    "servers": [
      {"type": "h3", "tag": "DNS", "server": "8.8.8.8", "detour": "direct"}
    ]
  },
  "inbounds": [
    {"type": "tun", "tag": "tun-in", "address": [ "172.19.0.1/30", "fdfe:dcba:9876::1/126"], "mtu": 1500, "stack": "gvisor", "auto_route": true, "auto_redirect": true, "route_address": ["0.0.0.0/1", "128.0.0.0/1", "::/1", "8000::/1"], "route_exclude_address": ["192.168.0.0/16", "fc00::/7"], "stack": "mixed"},
    {"type": "tuic", "tag": "tuic-in", "listen": "::", "listen_port": 443, "users": [{"uuid": "uuid",  "password": "ps"}], "congestion_control": "bbr", "tls": { "enabled": true, "alpn": ["h3"], "certificate_path": "/etc/cert.crt", "key_path": "/etc/cert.key"}},
    {"type": "anytls", "tag": "anytls-in", "listen": "::", "listen_port": 8443, "users": [{"name": "name", "password": "ps"}], "padding_scheme": [ "stop=8", "0=30-30", "1=100-400", "2=400-500,c,500-1000,c,500-1000,c,500-1000,c,500-1000", "3=9-9,500-1000", "4=500-1000", "5=500-1000", "6=500-1000", "7=500-1000" ], "tls": {"enabled": true, "server_name": "www.server.com", "certificate_path": "/etc/cert.crt", "key_path": "/etc/cert.key"}},
	 {"type": "vless", "tag": "vless-in", "listen": "::", "listen_port": 443, "users": [{"name": "name", "uuid": "uuid",  "flow": "xtls-rprx-vision"}], "tls": {"enabled": true, "server_name": "www.server.com", "reality": {"enabled": true, "handshake": {"server": "www.server.com", "server_port": 443}, "private_key":"key", "short_id": ["id"]}}},
    {"type": "hysteria2", "listen": "::", "listen_port": 8443, "users": [{"password": "ps"}], "masquerade": "https://www.server.com", "tls": {"enabled": true, "alpn": ["h3"], "certificate_path": "/etc/cert.crt", "key_path": "/etc/cert.key"}}
  ],
  "endpoints":[{"type": "wireguard", "tag": "wg", "system": true, "name": "wg0", "mtu": 1420, "address": ["172.16.0.2/32", "2606:4700:0000:1000::/128"], "private_key": "key", "workers": 2, "peers": [{"address": "162.159.193.1", "port": 2408, "public_key": "bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=", "pre_shared_key": "", "allowed_ips": ["0.0.0.0/0","::/0"], "persistent_keepalive_interval": 15, "reserved": "reserved"}]}],
  "outbounds": [
    {"type": "direct", "tag": "direct", "tcp_fast_open": true, "tcp_multi_path": true},
    {"type": "block", "tag": "block"}
  ],
  "route": {
    "default_domain_resolver": {"server": "DNS", "strategy": "prefer_ipv6"},
    "rules": [
      {"action": "sniff", "inbound": "tun-in"},
      {"action": "direct", "ip_is_private": true},
      {"action": "hijack-dns", "protocol": "dns"},
      {"type": "logical", "mode": "or", "rules": [{"port": 853}, {"network": "udp", "port": 443}, {"protocol": ["quic","stun"]}], "action": "reject"},
      {"action": "reject", "rule_set": ["geosite-google-ads", "geosite-category-ads-all"]},    
      {"rule_set": ["geoip-cn", "geosite-cn"], "outbound": "wg"}
    ],
    "rule_set": [
      {"tag": "geosite-duckduckgo", "type":"remote", "format":"binary", "url":"https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-duckduckgo.srs", "download_detour":"direct"},
      {"tag": "geosite-bilibili", "type":"remote", "format":"binary", "url":"https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/bilibili.srs", "download_detour":"direct"},
      {"tag": "geosite-twitter", "type":"remote", "format":"binary", "url":"https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-twitter.srs", "download_detour":"direct"},
      {"tag": "geosite-youtube", "type":"remote", "format":"binary", "url":"https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/youtube.srs", "download_detour":"direct"},
      {"tag": "geosite-google", "type":"remote", "format":"binary", "url":"https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/google.srs", "download_detour":"direct"},
      {"tag": "geosite-google-ads", "type":"remote", "format":"binary", "url":"https://github.com/SagerNet/sing-geosite/raw/refs/heads/rule-set/geosite-google-ads.srs", "download_detour":"direct"},
      {"tag": "geosite-category-ads-all", "type": "remote", "format": "binary", "url": "https://github.com/SagerNet/sing-geosite/raw/refs/heads/rule-set/geosite-category-ads-all.srs", "download_detour": "direct"},
      {"tag": "geosite-telegram", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/telegram.srs", "download_detour": "direct"},
      {"tag": "geoip-cn", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs", "download_detour": "direct"},
      {"tag": "geosite-cn", "type": "remote", "format": "binary", "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-cn.srs", "download_detour": "direct"}
    ],
    "final": "direct",
    "auto_detect_interface": true
  }
}
